# ============================================
# 造境 ZaoJing 后端环境变量配置
# ============================================
# 使用方法：复制本文件为 .env，填入实际的 API Key
#   cp .env.example .env
# 然后编辑 .env 填入你的密钥
#
# ---------- 按环境分离的模板文件 ----------
# 项目提供按环境分离的配置模板，推荐按需选用：
#   .env.development  — 开发环境模板（localhost、无需认证）
#   .env.production   — 生产环境模板（需配置认证与真实密钥）
#   .env.example      — 通用模板（本文件，包含全部变量说明）
#
# 按环境加载示例：
#   cp .env.development .env   # 开发
#   cp .env.production .env    # 生产
#
# 这些模板文件会提交到版本库；实际 .env 文件已被 .gitignore 忽略。

# ---------- 火山引擎（必需）----------
# 火山方舟 API Key，用于豆包文本模型 + Seedream 4.0 图片生成
# 申请地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
# 申请步骤：
#   1. 注册火山引擎账号 https://www.volcengine.com/
#   2. 完成实名认证
#   3. 进入「火山方舟」控制台
#   4. 在「模型广场」开通 doubao-seedream-4-0 和 doubao-1.5-pro
#   5. 在 API Key 管理页面创建 Key
VOLCENGINE_API_KEY=

# ---------- TMDB 电影数据（必需）----------
# TMDB API Key，用于热门电影、票房排行、电影详情
# 申请地址：https://www.themoviedb.org/settings/api
# 申请步骤：
#   1. 注册 TMDB 账号 https://www.themoviedb.org/
#   2. 验证邮箱
#   3. 进入 Account Settings -> API
#   4. 选择 Developer，接受条款
#   5. 填写应用名称和简介，提交后获取 API Key
TMDB_API_KEY=

# ---------- API 认证（生产环境必需）----------
# 用于保护 API 端点，防止未授权调用
# 所有请求（含同源浏览器请求）必须在请求头携带 X-API-Key
# 生产环境必须配置，留空则仅允许 localhost 访问
API_KEY=

# ---------- 管理员令牌（生产环境必需）----------
# 用于保护 /api/admin/* 端点（电影审核、数据刷新）
# 请求时需在请求头携带 X-Admin-Token
ADMIN_TOKEN=

# ---------- Prometheus 指标端点认证（生产环境推荐）----------
# 用于保护 /metrics 端点，防止未授权抓取内部运行指标
# 配置后，抓取请求需携带 Authorization: Bearer <METRICS_TOKEN>
# 留空则 /metrics 端点无需认证（仅适合内网/开发环境）
METRICS_TOKEN=

# ---------- CORS 白名单（生产环境需配置）----------
# 允许跨域访问的域名列表，逗号分隔
# 开发环境默认允许 localhost
# 生产环境填写你的部署域名，如：
# CORS_WHITELIST=https://your-domain.com,https://www.your-domain.com
CORS_WHITELIST=http://localhost:8127,http://127.0.0.1:8127

# ---------- 服务器配置 ----------
PORT=8127
NODE_ENV=development
# 静态文件目录（相对于 server/ 目录）
STATIC_DIR=../
# 反向代理跳数（部署在 Nginx/CDN 后设为 1，直连设为 0）
# 用于确保 req.ip 返回真实客户端 IP（速率限制、认证依赖此值）
TRUST_PROXY_HOPS=1

{
  "name": "zaojing-mvp",
  "version": "1.0.0",
  "description": "造境 AI 电影海报生成器",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "ANALYZE=true vite build",
    "check-bundle": "node scripts/check-bundle-size.js",
    "server": "cd server && node server.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint js/ server/ --ext .js,.ts",
    "format": "prettier --write \"js/**/*.{js,ts,css}\" \"server/**/*.js\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "js/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/**/*.js": [
      "prettier --write"
    ],
    "*.{css,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "poster",
    "movie",
    "canvas"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
